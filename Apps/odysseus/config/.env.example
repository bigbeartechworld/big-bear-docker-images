# Odysseus Environment Variables
# Copy to .env and edit.

# --- Auth & Security ---
AUTH_ENABLED=true
# CHANGE THIS BEFORE FIRST BOOT - leaving the placeholder blocks first boot
ODYSSEUS_ADMIN_PASSWORD=changeme
APP_BIND=0.0.0.0
APP_PORT=7000

# --- User mapping (entrypoint drops to these) ---
PUID=1000
PGID=1000

# --- Search ---
SEARXNG_INSTANCE=http://searxng:8080

# --- Vector store ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# --- LLM (user supplied) ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=
LLM_HOST=localhost
