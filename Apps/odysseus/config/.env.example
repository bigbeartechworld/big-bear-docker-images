# Odysseus Environment Variables
# Copy to .env and edit.

# --- Auth & Security ---
AUTH_ENABLED=true
# INSECURE DEFAULT - this becomes the real admin password. Change it before exposing the app.
ODYSSEUS_ADMIN_PASSWORD=changeme

# --- User mapping (entrypoint drops to these) ---
PUID=1000
PGID=1000

# --- Search ---
SEARXNG_INSTANCE=http://searxng:8080

# --- Vector store ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# --- LLM (user supplied) ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=
